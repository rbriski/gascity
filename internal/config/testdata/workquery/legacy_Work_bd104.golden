sh -c 'bd_or_fatal() { __bdf_out=$("$@" 2>/dev/null); __bdf_rc=$?; if [ $__bdf_rc -ne 0 ]; then __bdf_err=$("$@" 2>&1 >/dev/null); case "$__bdf_err" in *"schema version mismatch"*|*"Unable to open database"*) printf '\''%s\n'\'' "$__bdf_err" >&2; return 2 ;; esac; return 1; fi; printf '\''%s'\'' "$__bdf_out"; return 0; }; for id in "$GC_SESSION_ID" "$GC_SESSION_NAME" "$GC_ALIAS"; do [ -z "$id" ] && continue; legacy=""; case "$id" in *control-dispatcher) legacy="${id%control-dispatcher}workflow-control";; esac; for cand in "$id" "$legacy"; do [ -z "$cand" ] && continue; r=$(bd_or_fatal bd list --status in_progress --assignee="$cand" --json --limit=1); bd_rc=$?; [ $bd_rc -eq 2 ] && exit 1; [ -n "$r" ] && [ "$r" != "[]" ] && printf "%s" "$r" && exit 0; ebdq=$(bd_or_fatal bd query --json '\''ephemeral=true AND status=in_progress'\'' --limit=0); bd_rc=$?; [ $bd_rc -eq 2 ] && exit 1; r=$(printf '\''%s'\'' "$ebdq" | jq --arg id "$cand" '\''[.[] | select((.assignee // "") == $id)] | .[:1]'\'' 2>/dev/null); [ -n "$r" ] && [ "$r" != "[]" ] && printf "%s" "$r" && exit 0; done; done; for id in "$GC_SESSION_ID" "$GC_SESSION_NAME" "$GC_ALIAS"; do [ -z "$id" ] && continue; legacy=""; case "$id" in *control-dispatcher) legacy="${id%control-dispatcher}workflow-control";; esac; for cand in "$id" "$legacy"; do [ -z "$cand" ] && continue; r=$(bd_or_fatal bd ready --assignee="$cand" --json --limit=1); bd_rc=$?; [ $bd_rc -eq 2 ] && exit 1; [ -n "$r" ] && [ "$r" != "[]" ] && printf "%s" "$r" && exit 0; ebdq=$(bd_or_fatal bd query --json '\''ephemeral=true AND status=open'\'' --limit=0); bd_rc=$?; [ $bd_rc -eq 2 ] && exit 1; r=$(printf '\''%s'\'' "$ebdq" | jq --arg id "$cand" '\''[.[] | select((.assignee // "") == $id) | select(((.issue_type // .type // "") != "epic")) | select(([ (.dependencies // [])[] | select((.type // .dep_type // "") as $t | ($t == "blocks" or $t == "waits-for" or $t == "conditional-blocks")) | select((.status // .depends_on_status // "") != "closed") ] | length) == 0)] | sort_by(.created_at // "") | .[:1]'\'' 2>/dev/null); [ -n "$r" ] && [ "$r" != "[]" ] && printf "%s" "$r" && exit 0; done; done; case "$GC_SESSION_ORIGIN" in ephemeral|"") ;; *) exit 0 ;; esac; probe_pool_demand() { target="$1"; [ -z "$target" ] && return 1; r=$(bd_or_fatal bd ready --metadata-field "gc.routed_to=$target" --unassigned --exclude-type=epic --json --sort oldest --limit=20); bd_rc=$?; [ $bd_rc -eq 2 ] && exit 1; [ -n "$r" ] && [ "$r" != "[]" ] && printf "%s" "$r" && exit 0; legacy_candidates=$(bd_or_fatal bd ready --metadata-field "gc.run_target=$target" --metadata-field "gc.kind=workflow" --unassigned --exclude-type=epic --json --sort oldest --limit=20); bd_rc=$?; [ $bd_rc -eq 2 ] && exit 1; r=$(printf "%s" "$legacy_candidates" | jq '\''[.[] | select((.metadata["gc.routed_to"] // "") == "")] | .[:1]'\'' 2>/dev/null); [ -n "$r" ] && [ "$r" != "[]" ] && printf "%s" "$r" && exit 0; legacy_ephemeral_candidates=$(bdq=$(bd_or_fatal bd query --json '\''ephemeral=true AND status=open'\'' --limit=0); bd_rc=$?; [ $bd_rc -eq 2 ] && exit 2; [ $bd_rc -ne 0 ] && printf "[]" && exit 0; printf '\''%s'\'' "$bdq" | jq --arg target "$target" '\''[.[] | select((.assignee // "") == "") | select(((.metadata["gc.routed_to"] // "") == $target) or (((.metadata["gc.routed_to"] // "") == "") and ((.metadata["gc.run_target"] // "") == $target) and ((.metadata["gc.kind"] // "") == "workflow"))) | select(((.issue_type // .type // "") != "epic")) | select(([ (.dependencies // [])[] | select((.type // .dep_type // "") as $t | ($t == "blocks" or $t == "waits-for" or $t == "conditional-blocks")) | select((.status // .depends_on_status // "") != "closed") ] | length) == 0)] | sort_by(.created_at // "") | .[:20]'\'' 2>/dev/null || printf "[]"); bd_rc=$?; [ $bd_rc -eq 2 ] && exit 1; r=$(printf "%s" "$legacy_ephemeral_candidates" | jq '\''.[0:1]'\'' 2>/dev/null); [ -n "$r" ] && [ "$r" != "[]" ] && printf "%s" "$r" && exit 0; return 1; }; probe_pool_demand "$1"; probe_pool_demand "$2"; printf "[]"' -- rig/control-dispatcher rig/workflow-control