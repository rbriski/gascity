{"type":"excalidraw","version":2,"source":"gascity/designer","elements":[{"type":"text","id":"title","x":140,"y":15,"text":"WP-1: Compactor Interval Change — Operator Gate Flow","fontSize":20,"strokeColor":"#1e1e1e"},{"type":"rectangle","id":"current","x":50,"y":65,"width":200,"height":65,"backgroundColor":"#ffc9c9","fillStyle":"solid","roundness":{"type":3},"strokeColor":"#ef4444","strokeWidth":2,"label":{"text":"Current: interval=24h\n(risk: GB-scale journal)","fontSize":14}},{"type":"arrow","id":"a1","x":250,"y":97,"width":80,"height":0,"points":[[0,0],[80,0]],"strokeColor":"#1e1e1e","strokeWidth":2,"endArrowhead":"arrow"},{"type":"rectangle","id":"proposed","x":330,"y":65,"width":200,"height":65,"backgroundColor":"#fff3bf","fillStyle":"solid","roundness":{"type":3},"strokeColor":"#f59e0b","strokeWidth":2,"label":{"text":"Proposed: interval=2h\n(bounds to ~0.7 GB)","fontSize":14}},{"type":"diamond","id":"gate","x":575,"y":55,"width":185,"height":85,"backgroundColor":"#fff3bf","fillStyle":"solid","strokeColor":"#f59e0b","strokeWidth":3,"label":{"text":"Operator\napproval?","fontSize":16}},{"type":"arrow","id":"a_gate_in","x":530,"y":97,"width":45,"height":0,"points":[[0,0],[45,0]],"strokeColor":"#1e1e1e","strokeWidth":2,"endArrowhead":"arrow"},{"type":"arrow","id":"a_gate_no","x":668,"y":140,"width":0,"height":60,"points":[[0,0],[0,60]],"strokeColor":"#ef4444","strokeWidth":2,"endArrowhead":"arrow","label":{"text":"Denied","fontSize":14}},{"type":"rectangle","id":"blocked","x":580,"y":200,"width":175,"height":50,"backgroundColor":"#ffc9c9","fillStyle":"solid","roundness":{"type":3},"strokeColor":"#ef4444","strokeWidth":1,"label":{"text":"Bead stays blocked\n(pending-operator-approval)","fontSize":13}},{"type":"text","id":"note_approve","x":30,"y":180,"text":"Operator approval requires sign-off in bead notes covering:","fontSize":14,"strokeColor":"#1e1e1e"},{"type":"text","id":"n1","x":50,"y":200,"text":"- CPU impact acknowledged (gc dolt compact holds DB write lock during flatten)","fontSize":13,"strokeColor":"#757575"},{"type":"text","id":"n2","x":50,"y":218,"text":"- Off-peak scheduling considered (2h interval = 12x daily lock acquisitions)","fontSize":13,"strokeColor":"#757575"},{"type":"text","id":"n3","x":50,"y":236,"text":"- Alert configured: escalate if compact takes > 5 min","fontSize":13,"strokeColor":"#757575"},{"type":"text","id":"n4","x":50,"y":254,"text":"- Operator note posted: bd update ga-ox5oz8 --append-notes 'Approved: ...'","fontSize":13,"strokeColor":"#757575"},{"type":"rectangle","id":"impact","x":30,"y":280,"width":500,"height":75,"backgroundColor":"#ffd8a8","fillStyle":"solid","roundness":{"type":3},"strokeColor":"#f59e0b","strokeWidth":2},{"type":"text","id":"imp1","x":45,"y":290,"text":"Why the gate matters:","fontSize":15,"strokeColor":"#92400e"},{"type":"text","id":"imp2","x":45,"y":310,"text":"24h -> 2h = 12x more compact cycles per day. Each holds a write lock,","fontSize":13,"strokeColor":"#1e1e1e"},{"type":"text","id":"imp3","x":45,"y":328,"text":"stalling agent writes during flatten. Low impact at normal load;","fontSize":13,"strokeColor":"#1e1e1e"},{"type":"text","id":"imp4","x":45,"y":346,"text":"potential issue during bulk-write sessions or concurrent agent storms.","fontSize":13,"strokeColor":"#1e1e1e"},{"type":"rectangle","id":"benefit","x":550,"y":280,"width":220,"height":75,"backgroundColor":"#b2f2bb","fillStyle":"solid","roundness":{"type":3},"strokeColor":"#22c55e","strokeWidth":2},{"type":"text","id":"ben1","x":565,"y":290,"text":"Why it is worth it:","fontSize":15,"strokeColor":"#15803d"},{"type":"text","id":"ben2","x":565,"y":310,"text":"Bounds journal to ~0.7 GB","fontSize":13,"strokeColor":"#1e1e1e"},{"type":"text","id":"ben3","x":565,"y":328,"text":"vs 8.3 GB observed before","fontSize":13,"strokeColor":"#1e1e1e"},{"type":"text","id":"ben4","x":565,"y":346,"text":"the corruption incident.","fontSize":13,"strokeColor":"#1e1e1e"},{"type":"rectangle","id":"label_box","x":30,"y":375,"width":740,"height":50,"backgroundColor":"#dbe4ff","fillStyle":"solid","roundness":{"type":3},"strokeColor":"#4a9eed","strokeWidth":1},{"type":"text","id":"lb1","x":50,"y":385,"text":"Label: pending-operator-approval  |  Bead: ga-ox5oz8  |  File: examples/bd/dolt/orders/mol-dog-compactor.toml","fontSize":13,"strokeColor":"#2563eb"},{"type":"text","id":"lb2","x":50,"y":403,"text":"Change: interval = '24h'  ->  interval = '2h'  |  MUST NOT merge until approval note is on bead","fontSize":13,"strokeColor":"#2563eb"}],"appState":{"viewBackgroundColor":"#ffffff","currentItemFontFamily":1},"files":{}}