{
  "contract": {
    "name": "lumen.ir",
    "version": "0.2.5",
    "producer": "donbox/formula-language"
  },
  "name": "for-each-run-do",
  "input": {
    "name": "for-each-run-do.input",
    "fields": [
      {
        "name": "items",
        "type": { "kind": "array", "element": { "kind": "atomic", "name": "string" } },
        "required": true,
        "body": false
      },
      {
        "name": "label",
        "type": { "kind": "atomic", "name": "string" },
        "required": true,
        "body": false
      }
    ]
  },
  "nodes": [
    {
      "kind": "repeat",
      "id": "loop",
      "name": "loop",
      "after": [],
      "iterationName": "iteration",
      "body": {
        "kind": "run",
        "id": "stage",
        "name": "stage",
        "after": [],
        "target": { "kind": "by-name", "name": "reviewer" },
        "environment": {
          "fields": [
            {
              "name": "items",
              "value": { "kind": "expr", "expr": { "kind": "ref", "name": "items" } }
            },
            {
              "name": "label",
              "value": { "kind": "expr", "expr": { "kind": "ref", "name": "label" } }
            }
          ]
        },
        "outcome": "transparent"
      },
      "cond": {
        "kind": "operator",
        "op": "||",
        "operands": [
          {
            "kind": "operator",
            "op": "==",
            "operands": [
              { "kind": "ref", "name": "stage", "field": "outcome" },
              { "kind": "literal", "value": "pass" }
            ]
          },
          {
            "kind": "operator",
            "op": ">=",
            "operands": [
              { "kind": "ref", "name": "iteration" },
              { "kind": "literal", "value": 2 }
            ]
          }
        ]
      }
    }
  ],
  "formulas": {
    "reviewer": {
      "contract": {
        "name": "lumen.ir",
        "version": "0.2.5",
        "producer": "donbox/formula-language"
      },
      "name": "reviewer",
      "input": {
        "name": "reviewer.input",
        "fields": [
          {
            "name": "items",
            "type": { "kind": "array", "element": { "kind": "atomic", "name": "string" } },
            "required": true,
            "body": false
          },
          {
            "name": "label",
            "type": { "kind": "atomic", "name": "string" },
            "required": true,
            "body": false
          }
        ]
      },
      "nodes": [
        {
          "kind": "scatter",
          "id": "fanout",
          "name": "fanout",
          "after": [],
          "form": "each",
          "binder": "item",
          "over": { "kind": "ref", "name": "items" },
          "body": {
            "kind": "block",
            "id": "fanout.body",
            "after": [],
            "members": [
              {
                "kind": "do",
                "id": "review",
                "name": "review",
                "after": [],
                "source": { "kind": "prompt" },
                "interpreter": { "kind": "agent", "mode": { "kind": "do" } },
                "body": {
                  "raw": "Review {{ item }} for {{ label }}.",
                  "template": {
                    "parts": [
                      { "kind": "text", "value": "Review " },
                      { "kind": "interp", "expr": { "kind": "ref", "name": "item" } },
                      { "kind": "text", "value": " for " },
                      { "kind": "interp", "expr": { "kind": "ref", "name": "label" } },
                      { "kind": "text", "value": "." }
                    ]
                  },
                  "source": { "kind": "inline" },
                  "templated": true,
                  "language": "markdown",
                  "syntax": "bare"
                }
              }
            ]
          },
          "on_fail": "continue"
        }
      ]
    }
  }
}
