      "body": {
        "raw": "Note {{ note }}.",
        "template": {
          "parts": [
            {
              "kind": "text",
              "value": "Note "
            },
            {
              "kind": "interp",
              "expr": {
                "kind": "ref",
                "name": "note",
                "origin": {
                  "uri": "conformance/goldens/lumen-v0-ir/schema-input.formula",
