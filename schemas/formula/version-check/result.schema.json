    "ok",
    "bead_id",
    "formula_name",
    "bead_hash",
    "disk_hash",
    "match"
  ],
  "properties": {
    "schema_version": {
      "const": "1"
    },
    "ok": {
      "const": true
    },
    "bead_id": {
      "type": "string"
    },
    "formula_name": {
      "type": "string"
    },
    "bead_hash": {
      "type": "string"
    },
    "disk_hash": {
      "type": "string"
    },
    "match": {
      "type": "boolean"
    },
    "formula_path": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
