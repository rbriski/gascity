sh -c 'bd_or_fatal() { __bdf_out=$("$@" 2>/dev/null); __bdf_rc=$?; if [ $__bdf_rc -ne 0 ]; then __bdf_err=$("$@" 2>&1 >/dev/null); case "$__bdf_err" in *"schema version mismatch"*|*"Unable to open database"*) printf '\''%s\n'\'' "$__bdf_err" >&2; return 2 ;; esac; return 1; fi; printf '\''%s'\'' "$__bdf_out"; return 0; }; for id in "$GC_SESSION_ID" "$GC_SESSION_NAME" "$GC_ALIAS"; do [ -z "$id" ] && continue; legacy=""; case "$id" in *control-dispatcher) legacy="${id%control-dispatcher}workflow-control";; esac; for cand in "$id" "$legacy"; do [ -z "$cand" ] && continue; r=$(bd_or_fatal bd list --status in_progress --assignee="$cand" --json --limit=1); bd_rc=$?; [ $bd_rc -eq 2 ] && exit 1; [ -n "$r" ] && [ "$r" != "[]" ] && printf "%s" "$r" && exit 0; ebdq=$(bd_or_fatal bd query --json '\''ephemeral=true AND status=in_progress'\'' --limit=0); bd_rc=$?; [ $bd_rc -eq 2 ] && exit 1; r=$(printf '\''%s'\'' "$ebdq" | jq --arg id "$cand" '\''[.[] | select((.assignee // "") == $id)] | .[:1]'\'' 2>/dev/null); [ -n "$r" ] && [ "$r" != "[]" ] && printf "%s" "$r" && exit 0; done; done; printf "[]"'