sh -c 'bd_or_fatal() { __bdf_out=$("$@" 2>/dev/null); __bdf_rc=$?; if [ $__bdf_rc -ne 0 ]; then __bdf_err=$("$@" 2>&1 >/dev/null); case "$__bdf_err" in *"schema version mismatch"*|*"Unable to open database"*) printf '\''%s\n'\'' "$__bdf_err" >&2; return 2 ;; esac; return 1; fi; printf '\''%s'\'' "$__bdf_out"; return 0; }; case "$GC_SESSION_ORIGIN" in ephemeral|"") ;; *) exit 0 ;; esac; probe_pool_demand() { target="$1"; [ -z "$target" ] && return 1; r=$(bd_or_fatal bd ready --include-ephemeral --metadata-field "gc.routed_to=$target" --unassigned --exclude-type=epic --json --sort oldest --limit=20); bd_rc=$?; [ $bd_rc -eq 2 ] && exit 1; [ -n "$r" ] && [ "$r" != "[]" ] && printf "%s" "$r" && exit 0; legacy_candidates=$(bd_or_fatal bd ready --include-ephemeral --metadata-field "gc.run_target=$target" --metadata-field "gc.kind=workflow" --unassigned --exclude-type=epic --json --sort oldest --limit=20); bd_rc=$?; [ $bd_rc -eq 2 ] && exit 1; r=$(printf "%s" "$legacy_candidates" | jq '\''[.[] | select((.metadata["gc.routed_to"] // "") == "")] | .[:1]'\'' 2>/dev/null); [ -n "$r" ] && [ "$r" != "[]" ] && printf "%s" "$r" && exit 0; legacy_ephemeral_candidates=$(printf "[]"); bd_rc=$?; [ $bd_rc -eq 2 ] && exit 1; r=$(printf "%s" "$legacy_ephemeral_candidates" | jq '\''.[0:1]'\'' 2>/dev/null); [ -n "$r" ] && [ "$r" != "[]" ] && printf "%s" "$r" && exit 0; return 1; }; probe_pool_demand "$1"; printf "[]"' -- worker