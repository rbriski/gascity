{
  "contract": { "name": "lumen.ir", "version": "0.2.5", "producer": "donbox/formula-language" },
  "name": "recover-do",
  "input": {
    "name": "recover-do.input",
    "fields": [],
    "origin": { "uri": "examples/lumen/recover-do.lumen", "line": 0, "col": 0 }
  },
  "nodes": [
    {
      "kind": "recover",
      "id": "rec",
      "name": "charge",
      "after": [],
      "origin": { "uri": "examples/lumen/recover-do.lumen", "line": 2, "col": 0 },
      "guarded": {
        "kind": "settle",
        "id": "charge",
        "name": "charge",
        "after": [],
        "origin": { "uri": "examples/lumen/recover-do.lumen", "line": 1, "col": 0 },
        "outcome": "failed",
        "reason": "the card was declined",
        "publicOutcome": true
      },
      "body": {
        "kind": "do",
        "id": "refund",
        "name": "refund",
        "after": [],
        "origin": { "uri": "examples/lumen/recover-do.lumen", "line": 2, "col": 14 },
        "source": { "kind": "prompt" },
        "interpreter": {
          "kind": "agent",
          "mode": { "kind": "do" },
          "origin": { "uri": "examples/lumen/recover-do.lumen", "line": 2, "col": 14 }
        },
        "body": {
          "raw": "Reverse anything from {{ error.reason }}.",
          "template": {
            "parts": [
              { "kind": "text", "value": "Reverse anything from " },
              {
                "kind": "interp",
                "expr": {
                  "kind": "member",
                  "base": { "kind": "ref", "name": "error", "origin": { "uri": "examples/lumen/recover-do.lumen", "line": 2, "col": 14 } },
                  "name": "reason"
                },
                "origin": { "uri": "examples/lumen/recover-do.lumen", "line": 2, "col": 14 }
              },
              { "kind": "text", "value": "." }
            ]
          },
          "source": { "kind": "inline" },
          "templated": true,
          "language": "markdown",
          "syntax": "bare",
          "origin": { "uri": "examples/lumen/recover-do.lumen", "line": 2, "col": 14 }
        }
      },
      "errorBinding": "error"
    }
  ],
  "origin": { "uri": "examples/lumen/recover-do.lumen", "line": 0, "col": 0 }
}
