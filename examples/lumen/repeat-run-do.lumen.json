{
  "contract": {
    "name": "lumen.ir",
    "version": "0.2.5",
    "producer": "donbox/formula-language"
  },
  "name": "repeat-run-do",
  "input": {
    "name": "repeat-run-do.input",
    "fields": [
      {
        "name": "who",
        "type": { "kind": "atomic", "name": "string" },
        "required": true,
        "body": false
      }
    ]
  },
  "nodes": [
    {
      "kind": "repeat",
      "id": "loop",
      "name": "loop",
      "after": [],
      "iterationName": "iteration",
      "body": {
        "kind": "run",
        "id": "stage",
        "name": "stage",
        "after": [],
        "target": { "kind": "by-name", "name": "greeter" },
        "environment": {
          "fields": [
            {
              "name": "name",
              "value": { "kind": "expr", "expr": { "kind": "ref", "name": "who" } }
            }
          ]
        },
        "outcome": "transparent"
      },
      "cond": {
        "kind": "operator",
        "op": "||",
        "operands": [
          {
            "kind": "operator",
            "op": "==",
            "operands": [
              { "kind": "ref", "name": "stage", "field": "outcome" },
              { "kind": "literal", "value": "pass" }
            ]
          },
          {
            "kind": "operator",
            "op": ">=",
            "operands": [
              { "kind": "ref", "name": "iteration" },
              { "kind": "literal", "value": 2 }
            ]
          }
        ]
      }
    }
  ],
  "formulas": {
    "greeter": {
      "contract": {
        "name": "lumen.ir",
        "version": "0.2.5",
        "producer": "donbox/formula-language"
      },
      "name": "greeter",
      "input": {
        "name": "greeter.input",
        "fields": [
          {
            "name": "name",
            "type": { "kind": "atomic", "name": "string" },
            "required": true,
            "body": false
          }
        ]
      },
      "nodes": [
        {
          "kind": "do",
          "id": "hello",
          "name": "hello",
          "after": [],
          "source": { "kind": "prompt" },
          "interpreter": { "kind": "agent", "mode": { "kind": "do" } },
          "body": { "raw": "Say hello to {{ name }}, then settle this step." }
        }
      ]
    }
  }
}
