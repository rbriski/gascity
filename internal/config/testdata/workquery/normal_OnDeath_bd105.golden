bd_or_fatal() { __bdf_out=$("$@" 2>/dev/null); __bdf_rc=$?; if [ $__bdf_rc -ne 0 ]; then __bdf_err=$("$@" 2>&1 >/dev/null); case "$__bdf_err" in *"schema version mismatch"*|*"Unable to open database"*) printf '%s\n' "$__bdf_err" >&2; return 2 ;; esac; return 1; fi; printf '%s' "$__bdf_out"; return 0; }; assigned_raw=$(bd_or_fatal bd list --assignee=worker --status=in_progress --json); bd_rc=$?; [ $bd_rc -eq 2 ] && exit 1; assigned_rows=$(printf '%s' "$assigned_raw" | jq -r '.[] | [.id, (.metadata["gc.run_target"] // ""), (.metadata["gc.routed_to"] // "")] | @tsv' 2>/dev/null); ephemeral_raw=$(bd_or_fatal bd query --json 'ephemeral=true AND status=in_progress' --limit=0); bd_rc=$?; [ $bd_rc -eq 2 ] && exit 1; ephemeral_rows=$(printf '%s' "$ephemeral_raw" | jq -r --arg assignee 'worker' '.[] | select((.assignee // "") == $assignee) | [.id, (.metadata["gc.run_target"] // ""), (.metadata["gc.routed_to"] // "")] | @tsv' 2>/dev/null); { printf '%s\n' "$assigned_rows"; printf '%s\n' "$ephemeral_rows"; } | while IFS="$(printf '\t')" read -r id run_target routed_to; do [ -z "$id" ] && continue; if [ -n "$run_target" ] || [ -n "$routed_to" ]; then bd_or_fatal bd update "$id" --assignee "" --status open; bd_rc=$?; [ $bd_rc -eq 2 ] && exit 2; else bd_or_fatal bd update "$id" --assignee "" --status open --set-metadata 'gc.run_target=worker'; bd_rc=$?; [ $bd_rc -eq 2 ] && exit 2; fi; done; death_rc=$?; if [ $death_rc -eq 2 ]; then exit 1; fi