template='worker'; bd_or_fatal() { __bdf_out=$("$@" 2>/dev/null); __bdf_rc=$?; if [ $__bdf_rc -ne 0 ]; then __bdf_err=$("$@" 2>&1 >/dev/null); case "$__bdf_err" in *"schema version mismatch"*|*"Unable to open database"*) printf '%s\n' "$__bdf_err" >&2; return 2 ;; esac; return 1; fi; printf '%s' "$__bdf_out"; return 0; }; routed_raw=$(bd_or_fatal bd list --metadata-field "gc.routed_to=$template" --status=in_progress --no-assignee --json); bd_rc=$?; [ $bd_rc -eq 2 ] && exit 1; routed_ids=$(printf '%s' "$routed_raw" | jq -r '.[].id' 2>/dev/null); run_target_raw=$(bd_or_fatal bd list --metadata-field "gc.run_target=$template" --metadata-field "gc.kind=workflow" --status=in_progress --no-assignee --json); bd_rc=$?; [ $bd_rc -eq 2 ] && exit 1; run_target_ids=$(printf '%s' "$run_target_raw" | jq -r '.[] | select((.metadata["gc.routed_to"] // "") == "") | .id' 2>/dev/null); ephemeral_raw=$(bd_or_fatal bd query --json 'ephemeral=true AND status=in_progress' --limit=0); bd_rc=$?; [ $bd_rc -eq 2 ] && exit 1; ephemeral_ids=$(printf '%s' "$ephemeral_raw" | jq -r --arg template "$template" '.[] | select((.assignee // "") == "") | select(((.metadata["gc.routed_to"] // "") == $template) or (((.metadata["gc.routed_to"] // "") == "") and ((.metadata["gc.run_target"] // "") == $template) and ((.metadata["gc.kind"] // "") == "workflow"))) | .id' 2>/dev/null); { printf '%s\n' "$routed_ids"; printf '%s\n' "$run_target_ids"; printf '%s\n' "$ephemeral_ids"; } | awk 'NF && !seen[$0]++' | while IFS= read -r id; do [ -z "$id" ] && continue; bd_or_fatal bd update "$id" --status open; bd_rc=$?; [ $bd_rc -eq 2 ] && exit 2; done; boot_rc=$?; if [ $boot_rc -eq 2 ]; then exit 1; fi