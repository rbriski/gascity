      "source": {
        "kind": "prompt"
      },
      "interpreter": {
        "kind": "agent",
        "mode": {
          "kind": "do"
        },
        "origin": {
          "uri": "conformance/goldens/lumen-v0-ir/schema-input.formula",
          "line": 6,
          "col": 0
